# Copy this file to `.env` and fill in the values you have.
# `.env` is git-ignored. Every key is OPTIONAL except the Product Hunt pair.
# Leave a key blank to simply skip the retrievers that need it.

# --- GitHub (optional) ------------------------------------------------------
# Personal access token. Raises the rate limit from 60 to 5000 requests/hour.
# Create one (no scopes needed for public data): https://github.com/settings/tokens
GITHUB_TOKEN=

# --- Product Hunt (required for producthunt.py) -----------------------------
# Create an application: https://www.producthunt.com/v2/oauth/applications
#   Client type: Confidential.  Redirect URI: any https URL (unused by this flow).
# Then copy the API Key / API Secret below (the module exchanges them for a token).
PRODUCTHUNT_CLIENT_ID=
PRODUCTHUNT_CLIENT_SECRET=
# ...or paste a Developer Token instead of the id/secret pair:
PRODUCTHUNT_TOKEN=

# --- LinkedIn (optional) ----------------------------------------------------
# There is NO free/DIY LinkedIn API. Only set this if you subscribe to a
# licensed B2B enrichment provider and accept its terms + privacy obligations.
# See retrievers/linkedin.py for the compliance notes. Left blank = disabled.
LINKEDIN_PROVIDER_API_KEY=

# --- Twitter / X (optional) -------------------------------------------------
# Official API only. No free tier since Feb 2026 (pay-per-use, ~$0.01/lookup).
# Create a bearer token at https://developer.x.com after enabling billing.
X_BEARER_TOKEN=

# --- Web search (optional, but powers profile discovery) --------------------
# Set exactly ONE provider. Used to DISCOVER public profile URLs (LinkedIn/
# Twitter/GitHub) — compliant, since it returns search results, not scraped
# pages. Free tiers noted in retrievers/websearch.py.
TAVILY_API_KEY=
SERPAPI_API_KEY=
BRAVE_API_KEY=
# Google Custom Search needs both an API key and a search-engine id (cx):
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=
